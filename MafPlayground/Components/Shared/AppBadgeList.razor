@if (Items is not null && Items.Any())
{
    <div class="flex flex-wrap gap-2 mt-2">
        @foreach (var item in Items)
        {
            <span class="badge badge-@Variant @(Mono ? "font-mono" : "")">@item</span>
        }
    </div>
}
else
{
    <span class="text-sm">@EmptyText</span>
}

@code {
    [Parameter] public IEnumerable<string> Items { get; set; } = [];
    [Parameter] public string Variant             { get; set; } = "outline";
    [Parameter] public string EmptyText           { get; set; } = "—";
    [Parameter] public bool Mono                  { get; set; }
}
