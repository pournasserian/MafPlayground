@page "/admin/chat-clients/{Id}"
@rendermode InteractiveServer
@inject IChatClientService ChatClientService

<PageTitle>@(_client?.Id ?? "Chat Client") — Admin</PageTitle>

@if (_isLoading)
{
    <div class="flex justify-center items-center py-16">
        <span class="loading loading-spinner loading-lg"></span>
    </div>
}
else if (_client is null)
{
    <div class="alert alert-error max-w-md">
        <span>Chat client not found.</span>
        <a href="/admin/chat-clients" class="btn btn-sm btn-ghost">Back to list</a>
    </div>
}
else
{
    <!-- Breadcrumb -->
    <div class="breadcrumbs text-sm mb-4">
        <ul>
            <li><a href="/admin/chat-clients">Chat Clients</a></li>
            <li class="font-semibold">@_client.Id</li>
        </ul>
    </div>

    <!-- Header -->
    <div class="flex items-center justify-between mb-6">
        <div>
            <h1 class="text-2xl font-bold font-mono">@_client.Id</h1>
            <p class="text-sm opacity-60 mt-1">@_client.Description</p>
        </div>
        <a href="/admin/chat-clients" class="btn btn-ghost btn-sm">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
            </svg>
            Back
        </a>
    </div>

    <!-- Details Card -->
    <div class="card bg-base-100 shadow-sm">
        <div class="card-body">
            <h2 class="card-title text-base mb-4">Configuration</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
                @Field("Id", _client.Id, mono: true)
                @Field("Provider", _client.Provider)
                @Field("Model", _client.Model, mono: true)
                @Field("Endpoint", _client.Endpoint, mono: true)
                @Field("Organization Id", _client.OrganizationId)
                @Field("Project Id", _client.ProjectId)
                @Field("Max Retries", _client.MaxRetries?.ToString())
                @Field("Network Timeout (s)", _client.NetworkTimeout.HasValue ? ((int)_client.NetworkTimeout.Value.TotalSeconds).ToString() : null)
                @Field("Enable Distributed Tracing", _client.EnableDistributedTracing?.ToString())
                <div class="md:col-span-2 lg:col-span-3">
                    @Field("Description", _client.Description)
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public string Id { get; set; } = string.Empty;

    private ChatClient? _client;
    private bool _isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        _isLoading = true;
        _client = await ChatClientService.Get(Id);
        _isLoading = false;
    }

    private static RenderFragment Field(string label, string? value, bool mono = false) => __builder =>
    {
        __builder.OpenElement(0, "div");
        __builder.AddAttribute(1, "class", "flex flex-col gap-1");
        __builder.OpenElement(2, "span");
        __builder.AddAttribute(3, "class", "text-xs uppercase tracking-wide opacity-50 font-medium");
        __builder.AddContent(4, label);
        __builder.CloseElement();
        __builder.OpenElement(5, "span");
        __builder.AddAttribute(6, "class", $"text-sm {(mono ? "font-mono" : "")}");
        __builder.AddContent(7, string.IsNullOrEmpty(value) ? "—" : value);
        __builder.CloseElement();
        __builder.CloseElement();
    };
}
